{
  "name": "clooks",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "mkdir -p dist && bun build --compile --outfile dist/clooks src/cli.ts",
    "lint": "eslint src/",
    "lint:sh": "bash scripts/lint-sh.sh",
    "lint:all": "bun run lint && bun run lint:sh",
    "format": "prettier --write 'src/**/*.ts' '*.json' '*.mjs'",
    "format:check": "prettier --check 'src/**/*.ts' '*.json' '*.mjs'",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.10",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
