{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src",
    "test",
    "scripts/verify-types-emit.ts",
    "scripts/generate-types.ts",
    "scripts/generate-types.test.ts"
  ],
  "exclude": ["node_modules", "dist", "test/fixtures/github-raw"]
}
