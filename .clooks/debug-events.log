ed. Tells the teammate what to do next. */\\n    47→\\tfeedback: string;\\n    48→};\\n    49→export type StopResult = DebugFields & {\\n    50→\\tresult: \\\"stop\\\";\\n    51→\\treason: string;\\n    52→};\\n    53→export type PreToolUseResult = (AllowResult & InjectableContext & {\\n    54→\\t/** Modified tool input to pass to subsequent hooks and/or Claude Code. */\\n    55→\\tupdatedInput?: Record<string, unknown>;\\n    56→}) | (BlockResult & InjectableContext) | (SkipResult & InjectableContext);\\n    57→export type UserPromptSubmitResult = (AllowResult | BlockResult | SkipResult) & InjectableContext;\\n    58→export type PermissionRequestResult = AllowResult | BlockResult | SkipResult;\\n    59→export type StopEventResult = AllowResult | BlockResult | SkipResult;\\n    60→export type SubagentStopResult = AllowResult | BlockResult | SkipResult;\\n    61→export type ConfigChangeResult = AllowResult | BlockResult | SkipResult;\\n    62→export type SessionStartResult = SkipResult & InjectableContext;\\n    63→export type SessionEndResult = SkipResult;\\n    64→export type InstructionsLoadedResult = SkipResult;\\n    65→export type PostToolUseResult = SkipResult & InjectableContext;\\n    66→export type PostToolUseFailureResult = SkipResult & InjectableContext;\\n    67→export type NotificationResult = SkipResult & InjectableContext;\\n    68→export type SubagentStartResult = SkipResult & InjectableContext;\\n    69→export type WorktreeRemoveResult = SkipResult;\\n    70→export type PreCompactResult = SkipResult;\\n    71→export type WorktreeCreateResult = SuccessResult | FailureResult;\\n    72→export type TeammateIdleResult = ContinueResult | StopResult | SkipResult;\\n    73→export type TaskCompletedResult = ContinueResult | StopResult | SkipResult;\\n    74→export interface BaseContext {\\n    75→\\tevent: EventName;\\n    76→\\tsessionId: string;\\n    77→\\tcwd: string;\\n    78→\\tpermissionMode: PermissionMode;\\n    79→\\ttranscriptPath: string;\\n    80→\\tagentId?: string;\\n    81→\\tagentType?: string;\\n    82→\\t/** True when this hook is running in a parallel batch. */\\n    83→\\tparallel: boolean;\\n    84→\\t/** AbortSignal scoped to the current batch. Aborted when a parallel batch short-circuits. */\\n    85→\\tsignal: AbortSignal;\\n    86→}\\n    87→export interface PreToolUseContext extends BaseContext {\\n    88→\\tevent: \\\"PreToolUse\\\";\\n    89→\\ttoolName: string;\\n    90→\\t/** Current tool input — may differ from originalToolInput if a previous hook returned updatedInput. */\\n    91→\\ttoolInput: Record<string, unknown>;\\n    92→\\t/** The original tool input from Claude Code, before any hook modifications. */\\n    93→\\toriginalToolInput: Record<string, unknown>;\\n    94→\\ttoolUseId: string;\\n    95→}\\n    96→export interface UserPromptSubmitContext extends BaseContext {\\n    97→\\tevent: \\\"UserPromptSubmit\\\";\\n    98→\\tprompt: string;\\n    99→}\\n   100→export interface PermissionRequestContext extends BaseContext {\\n   101→\\tevent: \\\"PermissionRequest\\\";\\n   102→\\ttoolName: string;\\n   103→\\ttoolInput: Record<string, unknown>;\\n   104→\\tpermissionSuggestions: unknown[];\\n   105→}\\n   106→export interface StopContext extends BaseContext {\\n   107→\\tevent: \\\"Stop\\\";\\n   108→\\tstopHookActive: boolean;\\n   109→\\tlastAssistantMessage: string;\\n   110→}\\n   111→export interface SubagentStopContext extends BaseContext {\\n   112→\\tevent: \\\"SubagentStop\\\";\\n   113→\\tstopHookActive: boolean;\\n   114→\\tagentId: string;\\n   115→\\tagentType: string;\\n   116→\\tagentTranscriptPath: string;\\n   117→\\tlastAssistantMessage: string;\\n   118→}\\n   119→export interface ConfigChangeContext extends BaseContext {\\n   120→\\tevent: \\\"ConfigChange\\\";\\n   121→\\tsource: ConfigChangeSource;\\n   122→\\tfilePath?: string;\\n   123→}\\n   124→export interface SessionStartContext extends BaseContext {\\n   125→\\tevent: \\\"SessionStart\\\";\\n   126→\\tsource: SessionStartSource;\\n   127→\\tmodel?: string;\\n   128→}\\n   129→export interface SessionEndContext extends BaseContext {\\n   130→\\tevent: \\\"SessionEnd\\\";\\n   131→\\treason: SessionEndReason;\\n   132→}\\n   133→export interface InstructionsLoadedContext extends BaseContext {\\n   134→\\tevent: \\\"InstructionsLoaded\\\";\\n   135→\\tfilePath: string;\\n   136→\\tmemoryType: InstructionsMemoryType;\\n   137→\\tloadReason: InstructionsLoadReason;\\n   138→\\tglobs?: string[];\\n   139→\\ttriggerFilePath?: string;\\n   140→\\tparentFilePath?: string;\\n   141→}\\n   142→export interface PostToolUseContext extends BaseContext {\\n   143→\\tevent: \\\"PostToolUse\\\";\\n   144→\\ttoolName: string;\\n   145→\\ttoolInput: Record<string, unknown>;\\n   146→\\ttoolResponse: unknown;\\n   147→\\ttoolUseId: string;\\n   148→}\\n   149→export interface PostToolUseFailureContext extends BaseContext {\\n   150→\\tevent: \\\"PostToolUseFailure\\\";\\n   151→\\ttoolName: string;\\n   152→\\ttoolInput: Record<string, unknown>;\\n   153→\\ttoolUseId: string;\\n   154→\\terror: string;\\n   155→\\tisInterrupt: boolean;\\n   156→}\\n   157→export interface NotificationContext extends BaseContext {\\n   158→\\tevent: \\\"Notification\\\";\\n   159→\\tmessage: string;\\n   160→\\ttitle?: string;\\n   161→\\tnotificationType: NotificationType;\\n   162→}\\n   163→export interface SubagentStartContext extends BaseContext {\\n   164→\\tevent: \\\"SubagentStart\\\";\\n   165→\\tagentId: string;\\n   166→\\tagentType: string;\\n   167→}\\n   168→export interface WorktreeRemoveContext extends BaseContext {\\n   169→\\tevent: \\\"WorktreeRemove\\\";\\n   170→\\tworktreePath: string;\\n   171→}\\n   172→export interface PreCompactContext extends BaseContext {\\n   173→\\tevent: \\\"PreCompact\\\";\\n   174→\\ttrigger: PreCompactTrigger;\\n   175→\\tcustomInstructions: string;\\n   176→}\\n   177→export interface WorktreeCreateContext extends BaseContext {\\n   178→\\tevent: \\\"WorktreeCreate\\\";\\n   179→\\tname: string;\\n   180→}\\n   181→export interface TeammateIdleContext extends BaseContext {\\n   182→\\tevent: \\\"TeammateIdle\\\";\\n   183→\\tteammateName: string;\\n   184→\\tteamName: string;\\n   185→}\\n   186→export interface TaskCompletedContext extends BaseContext {\\n   187→\\tevent: \\\"TaskCompleted\\\";\\n   188→\\ttaskId: string;\\n   189→\\ttaskSubject: string;\\n   190→\\ttaskDescription?: string;\\n   191→\\tteammateName: string;\\n   192→\\tteamName: string;\\n   193→}\\n   194→export interface EventContextMap extends Record<EventName, unknown> {\\n   195→\\tPreToolUse: PreToolUseContext;\\n   196→\\tPostToolUse: PostToolUseContext;\\n   197→\\tUserPromptSubmit: UserPromptSubmitContext;\\n   198→\\tSessionStart: SessionStartContext;\\n   199→\\tSessionEnd: SessionEndContext;\\n   200→\\tStop: StopContext;\\n   201→\\tSubagentStop: SubagentStopContext;\\n   202→\\tSubagentStart: SubagentStartContext;\\n   203→\\tInstructionsLoaded: InstructionsLoadedContext;\\n   204→\\tPostToolUseFailure: PostToolUseFailureContext;\\n   205→\\tNotification: NotificationContext;\\n   206→\\tPermissionRequest: PermissionRequestContext;\\n   207→\\tConfigChange: ConfigChangeContext;\\n   208→\\tWorktreeCreate: WorktreeCreateContext;\\n   209→\\tWorktreeRemove: WorktreeRemoveContext;\\n   210→\\tPreCompact: PreCompactContext;\\n   211→\\tTeammateIdle: TeammateIdleContext;\\n   212→\\tTaskCompleted: TaskCompletedContext;\\n   213→}\\n   214→export interface EventResultMap extends Record<EventName, unknown> {\\n   215→\\tPreToolUse: PreToolUseResult;\\n   216→\\tPostToolUse: PostToolUseResult;\\n   217→\\tUserPromptSubmit: UserPromptSubmitResult;\\n   218→\\tSessionStart: SessionStartResult;\\n   219→\\tSessionEnd: SessionEndResult;\\n   220→\\tStop: StopEventResult;\\n   221→\\tSubagentStop: SubagentStopResult;\\n   222→\\tSubagentStart: SubagentStartResult;\\n   223→\\tInstructionsLoaded: InstructionsLoadedResult;\\n   224→\\tPostToolUseFailure: PostToolUseFailureResult;\\n   225→\\tNotification: NotificationResult;\\n   226→\\tPermissionRequest: PermissionRequestResult;\\n   227→\\tConfigChange: ConfigChangeResult;\\n   228→\\tWorktreeCreate: WorktreeCreateResult;\\n   229→\\tWorktreeRemove: WorktreeRemoveResult;\\n   230→\\tPreCompact: PreCompactResult;\\n   231→\\tTeammateIdle: TeammateIdleResult;\\n   232→\\tTaskCompleted: TaskCompletedResult;\\n   233→}\\n   234→export interface HookEventMeta {\\n   235→\\t/** Repo root via `git rev-parse --show-toplevel`. Null if not in a git repo. */\\n   236→\\tgitRoot: string | null;\\n   237→\\t/** Current branch. Null if detached HEAD or not in a git repo. */\\n   238→\\tgitBranch: string | null;\\n   239→\\t/** OS platform. */\\n   240→\\tplatform: \\\"darwin\\\" | \\\"linux\\\";\\n   241→\\t/** This hook's name (same as meta.name). */\\n   242→\\thookName: string;\\n   243→\\t/** Absolute path to the hook's .ts file. */\\n   244→\\thookPath: string;\\n   245→\\t/** ISO 8601 timestamp of engine invocation start. */\\n   246→\\ttimestamp: string;\\n   247→\\t/** Runtime version string. */\\n   248→\\tclooksVersion: string;\\n   249→\\t/** Path to the clooks.yml that registered this hook. */\\n   250→\\tconfigPath: string;\\n   251→}\\n   252→type BeforeHookEventVariants = {\\n   253→\\t[K in EventName]: {\\n   254→\\t\\ttype: K;\\n   255→\\t\\tinput: EventContextMap[K];\\n   256→\\t};\\n   257→}[EventName];\\n   258→export type BeforeHookEvent = {\\n   259→\\tmeta: HookEventMeta;\\n   260→\\trespond(result: BlockResult | SkipResult): void;\\n   261→} & BeforeHookEventVariants;\\n   262→type AfterHookEventVariants = {\\n   263→\\t[K in EventName]: {\\n   264→\\t\\ttype: K;\\n   265→\\t\\tinput: EventContextMap[K];\\n   266→\\t\\thandlerResult: EventResultMap[K];\\n   267→\\t\\trespond(result: EventResultMap[K]): void;\\n   268→\\t};\\n   269→}[EventName];\\n   270→export type AfterHookEvent = {\\n   271→\\tmeta: HookEventMeta;\\n   272→} & AfterHookEventVariants;\\n   273→export type MaybeAsync<T> = T | Promise<T>;\\n   274→export interface HookMeta<C extends Record<string, unknown> = Record<string, unknown>> {\\n   275→\\t/** Human-readable name. Must be unique within a project. */\\n   276→\\tname: string;\\n   277→\\t/** Optional description. */\\n   278→\\tdescription?: string;\\n   279→\\t/** Config defaults. Must satisfy the Config interface. */\\n   280→\\tconfig?: C;\\n   281→}\\n   282→export interface ClooksHook<C extends Record<string, unknown> = Record<string, unknown>> {\\n   283→\\tmeta: HookMeta<C>;\\n   284→\\t/** Runs before the matched event handler. Call event.respond() to block. */\\n   285→\\tbeforeHook?: (event: BeforeHookEvent, config: C) => MaybeAsync<void>;\\n   286→\\t/** Runs after the matched event handler completes normally. Call event.respond() to override. */\\n   287→\\tafterHook?: (event: AfterHookEvent, config: C) => MaybeAsync<void>;\\n   288→\\tPreToolUse?: (ctx: PreToolUseContext, config: C) => MaybeAsync<PreToolUseResult>;\\n   289→\\tUserPromptSubmit?: (ctx: UserPromptSubmitContext, config: C) => MaybeAsync<UserPromptSubmitResult>;\\n   290→\\tPermissionRequest?: (ctx: PermissionRequestContext, config: C) => MaybeAsync<PermissionRequestResult>;\\n   291→\\tStop?: (ctx: StopContext, config: C) => MaybeAsync<StopEventResult>;\\n   292→\\tSubagentStop?: (ctx: SubagentStopContext, config: C) => MaybeAsync<SubagentStopResult>;\\n   293→\\tConfigChange?: (ctx: ConfigChangeContext, config: C) => MaybeAsync<ConfigChangeResult>;\\n   294→\\tSessionStart?: (ctx: SessionStartContext, config: C) => MaybeAsync<SessionStartResult>;\\n   295→\\tSessionEnd?: (ctx: SessionEndContext, config: C) => MaybeAsync<SessionEndResult>;\\n   296→\\tInstructionsLoaded?: (ctx: InstructionsLoadedContext, config: C) => MaybeAsync<InstructionsLoadedResult>;\\n   297→\\tPostToolUse?: (ctx: PostToolUseContext, config: C) => MaybeAsync<PostToolUseResult>;\\n   298→\\tPostToolUseFailure?: (ctx: PostToolUseFailureContext, config: C) => MaybeAsync<PostToolUseFailureResult>;\\n   299→\\tNotification?: (ctx: NotificationContext, config: C) => MaybeAsync<NotificationResult>;\\n   300→\\tSubagentStart?: (ctx: SubagentStartContext, config: C) => MaybeAsync<SubagentStartResult>;\\n   301→\\tWorktreeRemove?: (ctx: WorktreeRemoveContext, config: C) => MaybeAsync<WorktreeRemoveResult>;\\n   302→\\tPreCompact?: (ctx: PreCompactContext, config: C) => MaybeAsync<PreCompactResult>;\\n   303→\\tWorktreeCreate?: (ctx: WorktreeCreateContext, config: C) => MaybeAsync<WorktreeCreateResult>;\\n   304→\\tTeammateIdle?: (ctx: TeammateIdleContext, config: C) => MaybeAsync<TeammateIdleResult>;\\n   305→\\tTaskCompleted?: (ctx: TaskCompletedContext, config: C) => MaybeAsync<TaskCompletedResult>;\\n   306→}\\n   307→\\n   308→export {};\\n   309→\"}]},\"uuid\":\"306edaf1-4a8d-4def-97c0-2a17cb2bd081\",\"timestamp\":\"2026-03-11T16:56:48.958Z\",\"sourceToolAssistantUUID\":\"afa2a799-00de-4a5c-b365-856980960526\"}\n{\"parentUuid\":\"306edaf1-4a8d-4def-97c0-2a17cb2bd081\",\"isSidechain\":true,\"userType\":\"external\",\"cwd\":\"/opt/development/clooks\",\"sessionId\":\"846423a7-b4c9-4a4e-ac08-b2f0d0b0dd9d\",\"version\":\"2.1.72\",\"gitBranch\":\"master\",\"agentId\":\"a26cf582658a09f6f\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01FDSJkvHkj2qxpX2bByH1RT\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"\\n\\nHere is a comprehensive report based on the official Claude Code hooks documentation at `https://code.claude.com/docs/en/hooks`.\\n\\n---\\n\\n## Complete Hook Events Reference (from official docs)\\n\\n**All 18 events are documented as fully implemented.** There is no mention of any event being \\\"planned\\\", \\\"experimental\\\", or \\\"spec-only\\\". The documentation provides full input schemas, output schemas, and examples for every event.\\n\\n---\\n\\n### Answers to Your Specific Questions\\n\\n**1. SubagentStart / SubagentStop -- do they actually fire? When?**\\n\\nYes, both are documented as implemented.\\n\\n- **SubagentStart**: fires when a subagent is spawned via the Agent tool. Matcher filters on agent type (`Bash`, `Explore`, `Plan`, or custom agent names from `.claude/agents/`). Input includes `agent_id` and `agent_type`. **Cannot block** subagent creation (exit code 2 just shows stderr to user). Can inject `additionalContext` into the subagent. Only supports `type: \\\"command\\\"` hooks.\\n\\n- **SubagentStop**: fires when a subagent finishes responding. Matcher filters on agent type (same values as SubagentStart). Input includes `stop_hook_active`, `agent_id`, `agent_type`, `agent_transcript_path`, and `last_assistant_message`. **Can block** the subagent from stopping (exit code 2 or `decision: \\\"block\\\"`). Supports all four hook types (command, http, prompt, agent).\\n\\n**2. TeammateIdle / TaskCompleted -- do they actually fire? When?**\\n\\nYes, both are documented as implemented. They are related to the **agent teams** feature.\\n\\n- **TeammateIdle**: fires when an agent team teammate is about to go idle after finishing its turn. No matcher support. Decision control via exit code 2 (teammate gets stderr feedback and continues) or `{\\\"continue\\\": false, \\\"stopReason\\\": \\\"...\\\"}` (stops teammate entirely). Only supports `type: \\\"command\\\"` hooks.\\n\\n- **TaskCompleted**: fires in two situations: (a) when any agent explicitly marks a task as completed through the TaskUpdate tool, or (b) when an agent team teammate finishes its turn with in-progress tasks. Input includes `task_id`, `task_subject`, `task_description`, `teammate_name`, `team_name`. Same decision control as TeammateIdle. Only supports `type: \\\"command\\\"` hooks.\\n\\n**3. Does Stop fire at the end of every turn?**\\n\\nStop fires \\\"when the main Claude Code agent has finished responding.\\\" It does **not** fire if the stoppage was due to a user interrupt. The input includes `stop_hook_active` (true when Claude is already continuing as result of a previous stop hook -- use this to prevent infinite loops) and `last_assistant_message`. Can block Claude from stopping via `decision: \\\"block\\\"` with a required `reason`. Supports all four hook types.\\n\\n**4. Does ConfigChange fire when settings files are edited?**\\n\\nYes. ConfigChange fires \\\"when a configuration file changes during a session.\\\" Matcher filters on source: `user_settings`, `project_settings`, `local_settings`, `policy_settings`, `skills`. Input includes `source` and optional `file_path`. **Can block** config changes (except `policy_settings` which cannot be blocked -- hooks fire for logging but blocking is ignored). Only supports `type: \\\"command\\\"` hooks.\\n\\n**Important caveat**: hooks are snapshotted at startup. Direct edits to hooks in settings files do not take effect immediately. Claude Code warns you and requires review in the `/hooks` menu before changes apply.\\n\\n**5. Does InstructionsLoaded fire when skills are loaded?**\\n\\nInstructionsLoaded fires \\\"when a CLAUDE.md or `.claude/rules/*.md` file is loaded into context.\\\" It fires at session start for eagerly-loaded files and later for lazily-loaded files (subdirectory CLAUDE.md, conditional rules with `paths:` frontmatter). The `load_reason` field can be: `session_start`, `nested_traversal`, `path_glob_match`, or `include`. There is no mention of it firing for skills specifically -- it is specifically about instruction/memory files. **No decision control.** Runs asynchronously for observability only. Exit code is ignored. Only supports `type: \\\"command\\\"` hooks.\\n\\n**6. Does PermissionRequest fire and under what conditions?**\\n\\nYes. PermissionRequest fires \\\"when a permission dialog is about to be shown to the user.\\\" This is distinct from PreToolUse -- PreToolUse fires before tool execution regardless of permission status, while PermissionRequest fires specifically when the user would be prompted. Matcher filters on tool name (same values as PreToolUse). Input includes `tool_name`, `tool_input`, and `permission_suggestions` array. **Can block** (deny) or allow permissions on behalf of the user. When allowing, can also provide `updatedInput` and `updatedPermissions`. Supports all four hook types.\\n\\n**7. How does hook output work for events outside tool calls?**\\n\\nThe JSON output mechanism is universal. All events support these universal fields:\\n- `continue` (default `true`) -- if `false`, Claude stops entirely\\n- `stopReason` -- message shown to user when `continue` is `false`\\n- `suppressOutput` (default `false`) -- hides stdout from verbose mode\\n- `systemMessage` -- warning message shown to user\\n\\nThe **decision control** varies by event:\\n\\n| Decision Pattern | Events |\\n|---|---|\\n| Top-level `decision: \\\"block\\\"` + `reason` | UserPromptSubmit, PostToolUse, PostToolUseFailure, Stop, SubagentStop, ConfigChange |\\n| Exit code 2 or `continue: false` | TeammateIdle, TaskCompleted |\\n| `hookSpecificOutput` with `permissionDecision` | PreToolUse |\\n| `hookSpecificOutput` with `decision.behavior` | PermissionRequest |\\n| stdout path | WorktreeCreate |\\n| **No decision control** (side effects only) | WorktreeRemove, Notification, SessionEnd, PreCompact, InstructionsLoaded |\\n\\nFor events that fire outside tool calls (Stop, ConfigChange, TeammateIdle, etc.), the hook receives JSON on stdin and returns JSON on stdout exactly the same way as tool-related events. The only difference is which decision fields are honored.\\n\\n---\\n\\n### Additional Key Findings\\n\\n**Error handling is NOT fail-closed by default in the native system.** Claude Code's behavior:\\n- Exit 0 = success, JSON parsed from stdout\\n- Exit 2 = blocking error (for events that support blocking)\\n- Any other exit code = **non-blocking error**, stderr shown in verbose mode, execution continues\\n\\nFor HTTP hooks, it is even more permissive: non-2xx responses and connection failures are all non-blocking errors.\\n\\n**Hook type support is split.** Not all events support all hook types:\\n- All four types (command, http, prompt, agent): PreToolUse, PostToolUse, PostToolUseFailure, PermissionRequest, Stop, SubagentStop, TaskCompleted, UserPromptSubmit\\n- Command only: ConfigChange, InstructionsLoaded, Notification, PreCompact, SessionEnd, SessionStart, SubagentStart, TeammateIdle, WorktreeCreate, WorktreeRemove\\n\\n**New fields since last types.d.ts update**: The docs mention `hook_event_name` as a common input field, and `PermissionRequest` has a `permission_suggestions` field (already in types.d.ts as `permissionSuggestions`). The `PostToolUse` docs now mention `updatedMCPToolOutput` for MCP tools. The `PermissionRequest` decision control has `updatedPermissions` and `interrupt` fields which clooks does not currently model.\\n\\n**Clooks types.d.ts alignment**: The types file at `/opt/development/clooks/.clooks/hooks/types.d.ts` already covers all 18 events and their contexts/results. The type definitions appear well-aligned with the documented contracts, with clooks abstracting the raw JSON into its own `result` enum pattern (allow/block/skip/continue/stop).\"}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":3,\"cache_creation_input_tokens\":11487,\"cache_read_input_tokens\":75908,\"cache_creation\":{\"ephemeral_5m_input_tokens\":11487,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"}},\"requestId\":\"req_011CYweQggSdsFGMKJkrGqZP\",\"type\":\"assistant\",\"uuid\":\"e6c6e577-7f1f-4019-98d1-28007ea72b1e\",\"timestamp\":\"2026-03-11T16:57:35.837Z\"}\n{\"parentUuid\":\"e6c6e577-7f1f-4019-98d1-28007ea72b1e\",\"isSidechain\":true,\"userType\":\"external\",\"cwd\":\"/opt/development/clooks\",\"sessionId\":\"846423a7-b4c9-4a4e-ac08-b2f0d0b0dd9d\",\"version\":\"2.1.72\",\"gitBranch\":\"master\",\"agentId\":\"a26cf582658a09f6f\",\"type\":\"p